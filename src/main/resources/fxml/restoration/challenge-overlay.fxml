<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="root"
           alignment="CENTER"
           prefWidth="1280"
           prefHeight="720"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="pkg.restoration.ui.challenge.ChallengeOverlayController">
    <children>
        <VBox maxWidth="780"
              prefWidth="780"
              spacing="14"
              style="-fx-background-color: #101711f2; -fx-background-radius: 8; -fx-border-color: #d7e77f; -fx-border-width: 1.6; -fx-border-radius: 8;"
              StackPane.alignment="CENTER">
            <padding>
                <Insets top="24" right="28" bottom="26" left="28"/>
            </padding>
            <children>
                <Text fx:id="title"
                      wrappingWidth="724"
                      fill="#d8e77f"
                      style="-fx-font-family: Verdana; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Text fx:id="prompt"
                      wrappingWidth="724"
                      fill="#f7f4dc"
                      style="-fx-font-family: Verdana; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <VBox fx:id="choiceBox" spacing="10"/>
            </children>
        </VBox>
    </children>
</StackPane>
